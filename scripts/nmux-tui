#!/usr/bin/env python3
# nmux-tui — ターミナル UI ダッシュボード for nmux
# Python 3.6+ / 標準ライブラリのみ（curses 使用）
# https://github.com/naotantan/nmux
import curses
import json
import os
import re
import subprocess
import sys
import time
from concurrent.futures import ThreadPoolExecutor, as_completed

# pane_id の許容フォーマット: %N（tmux pane_id）または session:window.pane
_PANE_ID_RE = re.compile(r'^%\d+$|^[\w-]+:\d+\.\d+$')

# ── 定数 ──────────────────────────────────────────────────────
NMUX_DIR    = os.path.join(os.environ.get("HOME", ""), ".nmux")
BIN_DIR     = os.path.join(NMUX_DIR, "bin")
BRIDGE      = os.path.join(BIN_DIR, "nmux-bridge")
DISPATCH    = os.path.join(BIN_DIR, "nmux-dispatch")
STATE_DIR   = os.path.join(NMUX_DIR, "state")

# ペイン数に応じた更新間隔（NMUX_TUI_INTERVAL で手動設定可）
_INTERVAL_SMALL = 1   # ≤20 ペイン: 1秒
_INTERVAL_LARGE = 3   # >20 ペイン: 3秒

# カラーペア番号
_C_HEADER   = 1   # ヘッダー行（青背景）
_C_BORDER   = 2   # 枠線（シアン）
_C_ONLINE   = 3   # オンライン（緑）
_C_OFFLINE  = 4   # オフライン（赤）
_C_LABEL    = 5   # ラベル（黄色）
_C_KEY      = 6   # キー表示（白太字）
_C_API_ON   = 7   # API オン（緑）
_C_API_OFF  = 8   # API オフ（赤）
_C_CONVERSE = 9   # converse ヘッダー（マゼンタ）


# ── ユーティリティ ─────────────────────────────────────────────
def _truncate(s, width):
    """文字列を width 文字以内に切り詰める（マルチバイト考慮なし）。"""
    s = str(s)
    return s if len(s) <= width else s[:width - 1] + "…"


def _safe_addstr(win, y, x, s, attr=0):
    """curses の範囲外書き込みを無視する addstr ラッパー。"""
    try:
        win.addstr(y, x, s, attr)
    except curses.error:
        pass


# ── データ取得 ─────────────────────────────────────────────────
def _dbg(msg):
    """NMUX_DEBUG=1 のとき stderr にデバッグログを出力する。"""
    if os.environ.get("NMUX_DEBUG", "0") == "1":
        print("[nmux-tui debug] {}".format(msg), file=sys.stderr)


def _get_pane_content(pane_id, lines=20):
    """tmux capture-pane で指定ペインの直近 N 行を取得し、ANSI エスケープを除去して返す。"""
    if not pane_id or not _PANE_ID_RE.match(pane_id):
        return []
    try:
        r = subprocess.run(
            ["tmux", "capture-pane", "-t", pane_id, "-p", "-S", "-{}".format(lines)],
            capture_output=True, text=True, timeout=2
        )
        if r.returncode == 0:
            ansi_esc = re.compile(r'\x1b\[[0-9;]*[mKHJA-Za-z]|\x1b\(B')
            return [ansi_esc.sub("", l).rstrip() for l in r.stdout.splitlines()]
    except Exception as e:
        _dbg("_get_pane_content({}): {}".format(pane_id, e))
    return []


def _get_panes():
    """nmux-bridge list --json でペイン情報を取得する。失敗は空リストを返す。"""
    try:
        r = subprocess.run(
            [BRIDGE, "list", "--json"],
            capture_output=True, text=True, timeout=3
        )
        if r.returncode == 0 and r.stdout.strip():
            return json.loads(r.stdout)
    except Exception as e:
        _dbg("_get_panes: {}".format(e))
    return []


# bash/zsh プロンプトや TUI アーティファクトとして無視するパターン
_PROMPT_RE = re.compile(
    r'^\s*[$%#>]\s*$'                        # 空プロンプト
    r'|.*\[q\]\s*終了.*'                      # TUI フッター行
    r'|.*\[q\]\s*Quit.*'                      # TUI フッター（英語）
    r'|^\s*$'                                  # 空行
    r'|^.*nmux_dashboard.*$'                   # TUI ヘッダー行
    r'|^TARGET\s+LABEL.*$|^場所\(tmux\)\s+名前.*$'  # TUI カラムヘッダー
    r'|^[─━─]+$'                              # TUI 区切り線
)

# AI プロセスとして認識するプロセス名
_AI_PROCS = {"claude", "python3", "python", "node", "ollama", "llm"}


def _get_last_output(pane_id):
    """tmux capture-pane で直近30行を取得し、意味のある最終行を返す。
    bash プロンプト・空行・TUI アーティファクトを除外する。
    """
    if not pane_id or not _PANE_ID_RE.match(pane_id):
        return "✗ OFFLINE", False

    try:
        r = subprocess.run(
            ["tmux", "capture-pane", "-t", pane_id, "-p", "-S", "-30"],
            capture_output=True, text=True, timeout=2
        )
        if r.returncode != 0:
            return "✗ OFFLINE", False

        # ANSI エスケープを除去してから判定
        ansi_esc = re.compile(r'\x1b\[[0-9;]*[mKHJA-Za-z]|\x1b\(B')
        lines = [ansi_esc.sub("", l) for l in r.stdout.splitlines()]
        # 意味のある行だけ残す
        meaningful = [l.rstrip() for l in lines if l.strip() and not _PROMPT_RE.match(l)]
        if meaningful:
            return meaningful[-1], False
        return "（待機中）", False

    except Exception as e:
        _dbg("_get_last_output({}): {}".format(pane_id, e))
    return "✗ OFFLINE", False


def _get_agent_status(process, last_output):
    """プロセス名と直近出力からエージェントのステータスを返す。

    Returns:
        tuple: (status_str, color_pair_id)
            status_str: 表示文字列（最大7文字）
            is_ai: AI プロセスかどうか
    """
    proc_lower = (process or "").lower().split("/")[-1]  # パスの basename
    is_ai = proc_lower in _AI_PROCS

    if "✗ OFFLINE" in last_output:
        return "OFFLINE", _C_OFFLINE, False
    if is_ai:
        return "AI稼働", _C_ONLINE, True
    if last_output == "（待機中）":
        return "待機中", _C_LABEL, False
    return "稼働中", _C_ONLINE, False


def _get_converse_sessions():
    """~/.nmux/state/converse/*.conf を読んでセッション情報を返す。
    STATUS が "running" のものを優先し、全セッションをリストで返す。

    Returns:
        list of dict: {name, agents, topic, status, started, log_path}
    """
    converse_dir = os.path.join(STATE_DIR, "converse")
    if not os.path.isdir(converse_dir):
        return []
    sessions = []
    try:
        for fname in sorted(os.listdir(converse_dir)):
            if not fname.endswith(".conf"):
                continue
            conf_path = os.path.join(converse_dir, fname)
            data = {}
            try:
                with open(conf_path, encoding="utf-8") as f:
                    for line in f:
                        line = line.strip()
                        if "=" in line:
                            k, v = line.split("=", 1)
                            data[k] = v.strip('"').strip("'")
            except OSError:
                continue
            name = data.get("NAME", fname[:-5])
            sessions.append({
                "name":     name,
                "agents":   data.get("AGENTS", "").split(),
                "topic":    data.get("TOPIC", ""),
                "status":   data.get("STATUS", ""),
                "started":  data.get("STARTED", ""),
                "log_path": os.path.join(converse_dir, name + ".log"),
            })
    except OSError as e:
        _dbg("_get_converse_sessions: {}".format(e))
    # running セッションを先に
    sessions.sort(key=lambda s: (0 if s["status"] == "running" else 1, s["name"]))
    return sessions


def _get_converse_log_info(log_path, max_exchanges=5):
    """converse ログを解析して会話情報を返す。

    Returns:
        dict: {
            "exchanges": list of (speaker, text),  # 直近の発言
            "current_turn": int,   # 直近ターン番号（0=不明）
            "total_turns":  int,   # 総ターン数（0=不明）
            "next_agent":   str,   # 次の発言予定エージェント（""=不明）
        }
    """
    result = {"exchanges": [], "current_turn": 0, "total_turns": 0, "next_agent": ""}
    if not os.path.isfile(log_path):
        return result

    ansi_esc  = re.compile(r'\x1b\[[0-9;]*[mKHJA-Za-z]|\x1b\(B|\x1b[()][AB012]')
    turn_re   = re.compile(r'\[Turn\s+(\d+)/(\d+)\].*?→\s*(\S+)')
    speaker_re = re.compile(r'^\[([^\]]+)\]\s*(.*)')

    try:
        with open(log_path, encoding="utf-8", errors="replace") as f:
            raw_lines = f.readlines()[-300:]
    except OSError:
        return result

    exchanges = []
    for line in raw_lines:
        clean = ansi_esc.sub("", line).rstrip()
        if not clean:
            continue
        # ターン情報の抽出
        tm = turn_re.search(clean)
        if tm:
            result["current_turn"] = int(tm.group(1))
            result["total_turns"]  = int(tm.group(2))
            result["next_agent"]   = tm.group(3)
            continue
        # エージェント発言の抽出
        sm = speaker_re.match(clean)
        if sm:
            speaker = sm.group(1)
            text    = sm.group(2).strip()
            # [Turn N/M] タイプやタイムスタンプ行をスキップ
            if re.match(r'^Turn\s+\d+', speaker):
                continue
            if re.match(r'\d{4}-', text) or text.startswith("to:"):
                continue
            if text and not re.match(r'^(TIMEOUT|SKIP)', text):
                exchanges.append((speaker, text))

    result["exchanges"] = exchanges[-max_exchanges:]
    return result


def _check_api():
    """API サーバーの稼働状況を PID ファイルで確認する。"""
    pid_file = os.path.join(STATE_DIR, "api.pid")
    if not os.path.isfile(pid_file):
        return False, ""
    try:
        with open(pid_file) as f:
            pid = int(f.read().strip())
        os.kill(pid, 0)   # シグナル 0: 存在確認のみ
        return True, ""
    except (OSError, ValueError) as e:
        _dbg("_check_api: {}".format(e))
    return False, ""


def _get_api_port():
    """nmux.conf から NMUX_API_PORT を読む。なければデフォルト 8765。"""
    conf_file = os.path.join(NMUX_DIR, "nmux.conf")
    if os.path.isfile(conf_file):
        try:
            with open(conf_file, encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if line.startswith("NMUX_API_PORT="):
                        port_str = line.split("=", 1)[1].strip().strip('"').strip("'")
                        # ポート番号の妥当性確認（1–65535 の整数）
                        if port_str.isdigit() and 1 <= int(port_str) <= 65535:
                            return port_str
        except OSError as e:
            _dbg("_get_api_port: {}".format(e))
    return os.environ.get("NMUX_API_PORT", "8765")


# ── TUI 本体 ──────────────────────────────────────────────────
class NmuxTUI:
    def __init__(self, stdscr):
        self.scr      = stdscr
        self.panes    = []
        self.cursor   = 0       # 選択中の行インデックス
        self.running  = True
        self.api_port = _get_api_port()

        # カラー初期化
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(_C_HEADER,  curses.COLOR_WHITE,  curses.COLOR_BLUE)
        curses.init_pair(_C_BORDER,  curses.COLOR_CYAN,   -1)
        curses.init_pair(_C_ONLINE,  curses.COLOR_GREEN,  -1)
        curses.init_pair(_C_OFFLINE, curses.COLOR_RED,    -1)
        curses.init_pair(_C_LABEL,   curses.COLOR_YELLOW, -1)
        curses.init_pair(_C_KEY,     curses.COLOR_WHITE,  -1)
        curses.init_pair(_C_API_ON,   curses.COLOR_GREEN,   -1)
        curses.init_pair(_C_API_OFF,  curses.COLOR_RED,     -1)
        curses.init_pair(_C_CONVERSE, curses.COLOR_MAGENTA, -1)

        curses.cbreak()
        curses.noecho()
        self.scr.keypad(True)
        self.scr.timeout(100)  # 100ms ごとにキー入力をポーリング

    # ── 更新間隔（ペイン数に基づく） ────────────────────────
    @property
    def interval(self):
        manual = os.environ.get("NMUX_TUI_INTERVAL", "")
        if manual.isdigit() and int(manual) > 0:
            return int(manual)
        return _INTERVAL_SMALL if len(self.panes) <= 20 else _INTERVAL_LARGE

    # ── ペイン行データ構築（並列フェッチ） ──────────────────
    def _build_pane_rows(self, col_widths):
        """ペインごとの表示文字列を返す。ThreadPoolExecutor で並列取得。

        Returns:
            list of dict: {target, label, status, status_color, is_ai, last, offline}
        """
        if not self.panes:
            return []

        # 各ペインの last_output を並列取得（I/O バウンドなのでスレッドが有効）
        def _fetch(pane):
            return pane, _get_last_output(pane.get("pane_id", ""))

        results = {}
        max_workers = min(len(self.panes), 8)  # 最大8スレッド
        with ThreadPoolExecutor(max_workers=max_workers) as pool:
            futures = {pool.submit(_fetch, p): i for i, p in enumerate(self.panes)}
            for fut in as_completed(futures):
                idx = futures[fut]
                try:
                    pane, (last_raw, _) = fut.result()
                    results[idx] = (pane, last_raw)
                except Exception as e:
                    _dbg("_build_pane_rows fetch[{}]: {}".format(idx, e))
                    results[idx] = (self.panes[idx], "✗ OFFLINE")

        rows = []
        for idx in range(len(self.panes)):
            pane, last_raw = results.get(idx, (self.panes[idx], "✗ OFFLINE"))
            process     = pane.get("process", "")
            status_str, status_color, is_ai = _get_agent_status(process, last_raw)
            last        = _truncate(last_raw, col_widths["out"])
            rows.append({
                "target":       _truncate(pane.get("target", ""),  col_widths["target"]),
                "label":        _truncate(pane.get("label",  ""),  col_widths["label"]),
                "status":       "{:<{}}".format(status_str, col_widths["status"]),
                "status_color": status_color,
                "is_ai":        is_ai,
                "last":         last,
                "offline":      "OFFLINE" in last_raw or "✗" in last_raw,
            })
        return rows

    # ── 画面描画 ─────────────────────────────────────────────
    def _draw(self):
        self.scr.clear()
        max_y, max_x = self.scr.getmaxyx()

        # _draw() 内で再利用するデータをキャッシュ（複数回の file I/O を防ぐ）
        _cached_conv_sessions = _get_converse_sessions()

        # ── ヘッダー行 ─────────────────────────────────────
        api_on, _ = _check_api()
        ts    = time.strftime("%Y-%m-%d %H:%M:%S")
        api_s = "●  稼働中 (:{}  )".format(self.api_port) if api_on else "○  停止中"
        # API ON/OFF で色を分ける（_C_API_ON: 緑 / _C_API_OFF: 赤）
        api_color = curses.color_pair(_C_API_ON) if api_on else curses.color_pair(_C_API_OFF)
        header      = " nmux dashboard "
        meta_prefix = "  {}   REST API: ".format(ts)
        meta_suffix = "  "
        _safe_addstr(self.scr, 0, 0, header, curses.color_pair(_C_HEADER) | curses.A_BOLD)
        x = len(header)
        _safe_addstr(self.scr, 0, x, meta_prefix[:max_x - x], curses.color_pair(_C_HEADER))
        x += len(meta_prefix)
        _safe_addstr(self.scr, 0, x, api_s[:max(0, max_x - x)], api_color)
        x += len(api_s)
        _safe_addstr(self.scr, 0, x, meta_suffix[:max(0, max_x - x)], curses.color_pair(_C_HEADER))
        x += len(meta_suffix)
        # 残幅を埋める
        fill = max(0, max_x - x)
        _safe_addstr(self.scr, 0, x, " " * fill, curses.color_pair(_C_HEADER))

        # ── エージェント集計 + converse稼働数（ヘッダー右端に表示） ──────
        total  = len(self.panes)
        active = sum(
            1 for p in self.panes
            if (p.get("process", "").lower().split("/")[-1] in _AI_PROCS)
        )
        running_conv_count = sum(
            1 for s in _cached_conv_sessions if s["status"] == "running"
        )
        conv_part = "  会話: {}件".format(running_conv_count) if running_conv_count else ""
        agent_summary = " AI稼働: {}/{}{}".format(active, total, conv_part)
        _safe_addstr(self.scr, 0, max(0, max_x - len(agent_summary) - 2),
                     agent_summary[:max_x], curses.color_pair(_C_HEADER))

        # ── カラムヘッダー ──────────────────────────────────
        col_w = {"target": 14, "label": 10, "status": 8}
        out_w = max(10, max_x - col_w["target"] - col_w["label"] - col_w["status"] - 4)
        fmt   = "{:<{}} {:<{}} {:<{}} {:<{}}".format(
            "場所(tmux)",  col_w["target"],
            "名前",        col_w["label"],
            "状態",        col_w["status"],
            "最新の出力",  out_w,
        )
        _safe_addstr(self.scr, 1, 0, fmt[:max_x], curses.A_BOLD)

        # 区切り線
        line = "─" * min(max_x, col_w["target"] + col_w["label"] + col_w["status"] + out_w + 3)
        _safe_addstr(self.scr, 2, 0, line, curses.color_pair(_C_BORDER))

        # ── ペイン行（_build_pane_rows で構築したデータを描画） ─
        col_widths = {"target": col_w["target"], "label": col_w["label"],
                      "status": col_w["status"], "out": out_w}
        pane_rows = self._build_pane_rows(col_widths)
        for idx, prow in enumerate(pane_rows):
            row = idx + 3
            if row >= max_y - 2:
                break

            attr = curses.A_REVERSE if idx == self.cursor else 0
            _safe_addstr(self.scr, row, 0,
                "{:<{}}".format(prow["target"],  col_w["target"])[:max_x], attr)
            col = col_w["target"] + 1
            _safe_addstr(self.scr, row, col,
                "{:<{}}".format(prow["label"], col_w["label"])[:max(0, max_x - col)],
                attr | curses.color_pair(_C_LABEL))
            col += col_w["label"] + 1
            # STATUS: 色付き
            status_attr = curses.color_pair(prow["status_color"])
            if prow["is_ai"]:
                status_attr |= curses.A_BOLD
            _safe_addstr(self.scr, row, col,
                prow["status"][:max(0, max_x - col)],
                attr | status_attr)
            col += col_w["status"] + 1
            # LAST OUTPUT: OFFLINE=赤 / 待機中=暗め / その他=緑
            if prow["offline"]:
                out_attr = curses.color_pair(_C_OFFLINE)
            elif "待機中" in prow["last"]:
                out_attr = curses.color_pair(_C_KEY)
            else:
                out_attr = curses.color_pair(_C_ONLINE)
            _safe_addstr(self.scr, row, col,
                "{:<{}}".format(prow["last"], out_w)[:max(0, max_x - col)],
                attr | out_attr)

        # ── 下部パネル（会話ビュー / converse リアルタイム表示） ──
        # ペイン行数 + ヘッダー3行 = 下部パネルの開始行
        list_end_row = len(pane_rows) + 3
        # フッター1行を確保した上での利用可能行数
        lower_available = max_y - list_end_row - 1

        if lower_available >= 4:
            div_y    = list_end_row
            div_line = "─" * min(max_x, 60)

            # ── アクティブな converse セッションがあれば優先表示 ──
            conv_sessions    = _cached_conv_sessions
            running_sessions = [s for s in conv_sessions if s["status"] == "running"]

            if running_sessions:
                # running セッションを最大2つ表示（各セッションに行を均等分配）
                slots    = min(len(running_sessions), 2)
                rows_per = max(4, lower_available // slots)

                # エージェントごとに色を割り当てるカラーサイクル
                agent_colors = [_C_CONVERSE, _C_LABEL, _C_ONLINE, _C_BORDER]

                cur_y = div_y
                for si, sess in enumerate(running_sessions[:slots]):
                    if cur_y >= max_y - 1:
                        break

                    # ── セッションヘッダー ──
                    agents_str  = " ⟷ ".join(sess["agents"]) if sess["agents"] else "?"
                    topic_short = _truncate(sess["topic"], max(0, max_x - len(agents_str) - 20))
                    _safe_addstr(self.scr, cur_y, 0,
                        div_line, curses.color_pair(_C_BORDER))

                    log_info = _get_converse_log_info(sess["log_path"], max_exchanges=rows_per - 2)
                    turn_s   = ""
                    if log_info["total_turns"] > 0:
                        turn_s = "  Turn {}/{}".format(
                            log_info["current_turn"], log_info["total_turns"])
                    next_s = ""
                    if log_info["next_agent"]:
                        next_s = "  → {}".format(log_info["next_agent"])

                    # セッションヘッダーバー（背景色付き・全幅）
                    sess_title = " ● 会話中: {}  [{}]{}{}  {}".format(
                        sess["name"], agents_str, turn_s, next_s, topic_short)
                    # 全幅を背景色で埋めてからテキストを上書き
                    _safe_addstr(self.scr, cur_y, 0,
                        " " * max_x,
                        curses.color_pair(_C_HEADER))
                    _safe_addstr(self.scr, cur_y, 0,
                        sess_title[:max_x],
                        curses.color_pair(_C_HEADER) | curses.A_BOLD)
                    cur_y += 1

                    # ── 会話ログ（発話ごとに整列・色分け） ──
                    # 最長話者名を算出して列幅を揃える
                    max_spk_len = max(
                        (len(sp) for sp, _ in log_info["exchanges"]), default=8)
                    max_spk_len = min(max_spk_len, 12)

                    agent_color_map = {}
                    color_idx = 0
                    for (speaker, text) in log_info["exchanges"]:
                        if cur_y >= max_y - 1:
                            break
                        # 発話者ごとに固定色を割り当て
                        if speaker not in agent_color_map:
                            agent_color_map[speaker] = agent_colors[
                                color_idx % len(agent_colors)]
                            color_idx += 1
                        lattr  = curses.color_pair(agent_color_map[speaker]) | curses.A_BOLD
                        # "▶ speaker-name : text" 形式で発話者を固定幅に揃える
                        label  = "  ▶ {:<{}} ".format(
                            _truncate(speaker, max_spk_len), max_spk_len)
                        line   = label + _truncate(
                            text, max(0, max_x - len(label) - 1))
                        # 話者名部分と本文で色を分ける
                        _safe_addstr(self.scr, cur_y, 0, label[:max_x], lattr)
                        if len(label) < max_x:
                            _safe_addstr(self.scr, cur_y, len(label),
                                _truncate(text, max(0, max_x - len(label)))[:max(0, max_x - len(label))],
                                curses.color_pair(_C_KEY))
                        cur_y += 1

            elif self.panes:
                # converse が動いていなければ選択ペインの直近出力を表示（既来の挙動）
                sel_pane  = self.panes[min(self.cursor, len(self.panes) - 1)]
                sel_label = sel_pane.get("label", sel_pane.get("target", "?"))
                pane_id   = sel_pane.get("pane_id", "")

                _safe_addstr(self.scr, div_y, 0, div_line, curses.color_pair(_C_BORDER))
                title = " 📺 {} — 直近の出力 ".format(sel_label)
                _safe_addstr(self.scr, div_y, 2, title[:max_x - 2], curses.A_BOLD)

                content_lines = _get_pane_content(pane_id, lines=lower_available)
                content_lines = content_lines[-(lower_available - 1):]
                for ci, cline in enumerate(content_lines):
                    cy = div_y + 1 + ci
                    if cy >= max_y - 1:
                        break
                    is_msg = bool(re.search(r'\[.*→.*\]|\[nmux\]', cline))
                    cattr  = (curses.color_pair(_C_LABEL) | curses.A_BOLD) if is_msg \
                             else curses.color_pair(_C_ONLINE) if cline.strip() \
                             else 0
                    _safe_addstr(self.scr, cy, 0,
                        _truncate(cline, max_x).ljust(min(max_x, len(cline) + 1))[:max_x],
                        cattr)

        # ── フッター（キー一覧） ────────────────────────────
        footer_y = max_y - 1
        conv_sessions_active = any(
            s["status"] == "running" for s in _cached_conv_sessions
        )
        stop_key = "  [s] 会話停止" if conv_sessions_active else ""
        keys = "  [q] 終了  [r] 即時更新  [Enter] このペインへ移動  [d] タスク一括送信  " \
               "[↑↓] 移動{}  ● 自動更新: {}s".format(stop_key, self.interval)
        _safe_addstr(self.scr, footer_y, 0,
            keys[:max_x], curses.color_pair(_C_KEY))

        self.scr.refresh()

    # ── インライン文字入力ヘルパー ────────────────────────────
    def _get_user_input(self, prompt):
        """フッター行にプロンプトを表示してユーザー入力を受け取る。

        Returns:
            str | None: 確定した入力文字列。ESC キャンセル時は None。
        """
        max_y, max_x = self.scr.getmaxyx()
        buf = ""

        curses.echo()
        curses.curs_set(1)

        while True:
            display = (prompt + buf)[:max_x]
            _safe_addstr(self.scr, max_y - 1, 0, display.ljust(max_x), curses.A_REVERSE)
            self.scr.refresh()
            try:
                ch = self.scr.get_wch()
            except curses.error:
                continue
            if ch == 27:                                    # ESC → キャンセル
                buf = None
                break
            if ch in ("\n", "\r", curses.KEY_ENTER, 10):   # Enter → 確定
                break
            if ch in (curses.KEY_BACKSPACE, 127, "\x7f"):
                buf = buf[:-1]
            elif isinstance(ch, str) and ch.isprintable():
                buf += ch

        curses.noecho()
        curses.curs_set(0)
        return buf

    # ── dispatch ファイル指定ダイアログ ──────────────────────
    def _dispatch_dialog(self):
        prompt = " タスク一括送信: JSON ファイルパスを入力 (ESC でキャンセル): "
        path = self._get_user_input(prompt)
        if path and path.strip():
            self._run_dispatch(path.strip())

    def _run_dispatch(self, path):
        """nmux-dispatch を実行し、結果をオーバーレイ表示する。"""
        if not os.path.isfile(path):
            self._alert("ファイルが見つかりません: {}".format(path), error=True)
            return
        r = None  # returncode 参照前に初期化しておく
        try:
            r = subprocess.run(
                [DISPATCH, path],
                capture_output=True, text=True, timeout=300
            )
            msg = "dispatch 完了 (exit {})".format(r.returncode)
        except subprocess.TimeoutExpired:
            msg = "dispatch タイムアウト"
        except Exception as exc:
            _dbg("_run_dispatch: {}".format(exc))
            msg = "dispatch エラー: {}".format(exc)
        self._alert(msg, error=(r.returncode != 0) if r else True)

    def _alert(self, msg, error=False):
        """画面下部に一時メッセージを表示し、キー入力を待つ。"""
        max_y, max_x = self.scr.getmaxyx()
        attr = curses.color_pair(_C_OFFLINE) if error else curses.color_pair(_C_ONLINE)
        full = "  {}  [任意のキーで閉じる]".format(msg)
        _safe_addstr(self.scr, max_y - 1, 0, full[:max_x].ljust(max_x), attr)
        self.scr.refresh()
        self.scr.timeout(-1)  # ブロッキング待機
        self.scr.getch()
        self.scr.timeout(100)

    # ── converse 停止ダイアログ ───────────────────────────────
    def _stop_converse_dialog(self):
        """実行中の converse セッションを選択・停止する。"""
        running = [s for s in _get_converse_sessions() if s["status"] == "running"]
        if not running:
            self._alert("実行中の会話セッションはありません")
            return

        if len(running) == 1:
            name = running[0]["name"]
        else:
            # 複数ある場合はセッション名を入力させる
            names = ", ".join(s["name"] for s in running)
            prompt = " 停止するセッション名を入力 ({}):  ".format(names)
            name = self._get_user_input(prompt).strip()
            if not name:
                return

        converse_bin = os.path.join(BIN_DIR, "nmux-converse")
        try:
            r = subprocess.run(
                [converse_bin, "stop", name],
                capture_output=True, text=True, timeout=10
            )
            msg = "会話 '{}' を停止しました".format(name) \
                  if r.returncode == 0 else "停止失敗: {}".format(r.stderr.strip()[:60])
        except Exception as e:
            msg = "エラー: {}".format(e)
        self._alert(msg, error=(msg.startswith("停止失敗") or msg.startswith("エラー")))

    # ── ペイン選択（Enter） ──────────────────────────────────
    def _select_pane(self):
        if not self.panes:
            return
        pane = self.panes[self.cursor]
        target = pane.get("target", "")
        if not target:
            return
        try:
            subprocess.run(["tmux", "select-pane", "-t", pane.get("pane_id", target)])
        except Exception as e:
            _dbg("_select_pane: {}".format(e))

    # ── メインループ ─────────────────────────────────────────
    def run(self):
        last_refresh = 0.0
        curses.curs_set(0)

        while self.running:
            now = time.time()
            if now - last_refresh >= self.interval:
                self.panes    = _get_panes()
                last_refresh  = now
                # カーソルを有効範囲に収める
                if self.panes:
                    self.cursor = min(self.cursor, len(self.panes) - 1)
                self._draw()

            try:
                key = self.scr.getch()
            except curses.error:
                continue

            if key == -1:
                continue

            if key in (ord("q"), ord("Q")):
                self.running = False

            elif key in (ord("r"), ord("R")):
                last_refresh = 0  # 次のループで即更新

            elif key in (curses.KEY_UP, ord("k")):
                if self.cursor > 0:
                    self.cursor -= 1
                self._draw()

            elif key in (curses.KEY_DOWN, ord("j")):
                if self.cursor < len(self.panes) - 1:
                    self.cursor += 1
                self._draw()

            elif key in (curses.KEY_ENTER, 10, 13):
                self._select_pane()

            elif key in (ord("d"), ord("D")):
                self._dispatch_dialog()
                last_refresh = 0  # 操作後に即更新

            elif key in (ord("s"), ord("S")):
                self._stop_converse_dialog()
                last_refresh = 0


# ── エントリーポイント ─────────────────────────────────────────
def main():
    try:
        curses.wrapper(lambda scr: NmuxTUI(scr).run())
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()
